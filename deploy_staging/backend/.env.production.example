# ============================================================
# Шаблон .env для ПРОДАКШНА
# Скопировать в backend/.env на сервере и заполнить реальными значениями
# ============================================================

# Django
DJANGO_SECRET_KEY=СГЕНЕРИРУЙ_НОВЫЙ_КЛЮЧ_python_-c_"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False

# База данных PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=crisha_db
DB_USER=crisha_user
DB_PASSWORD=СЛОЖНЫЙ_ПАРОЛЬ_БД
DB_HOST=localhost
DB_PORT=5432

# AI API
DEEPSEEK_API_KEY=ВАШ_КЛЮЧ_POLZA_AI
USE_MOCK_AI=False

# YooKassa (боевой режим)
YOOKASSA_SHOP_ID=ВАШ_SHOP_ID
YOOKASSA_SECRET_KEY=ВАШ_SECRET_KEY

# Redis (для Celery)
REDIS_URL=redis://localhost:6379/0
